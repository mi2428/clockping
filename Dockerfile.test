FROM rust:1-bookworm

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ca-certificates \
        iproute2 \
        iputils-ping \
        python3 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work

COPY Cargo.toml Cargo.lock README.md ./
COPY src ./src
COPY tests ./tests

RUN cargo build --locked

CMD ["bash", "tests/e2e/run.sh"]
